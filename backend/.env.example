# ──────────────────────────────────────────────
# UPAO-MAS-EDU — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────

# Application
ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://upao_user:upao_pass@localhost:5432/upao_mas_edu

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# JWT
SECRET_KEY=cambia-esto-en-produccion-genera-uno-aleatorio-de-32-bytes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ──────────────────────────────────────────────
# API Keys (required for AI & search features)
# ──────────────────────────────────────────────
# Get a key at https://app.tavily.com
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# Optional: FFMPEG for multimodal processing
# ──────────────────────────────────────────────
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
